---
// src/components/HeroSlider.astro
// slides: getActiveHeroSlides() çıktısı. Bu bileşen Simpa ve Superpress'te
// birebir aynı dosya olarak kullanılır — marka renkleri/fontları kendi
// global.css'lerindeki CSS değişkenlerinden (--navy, --cond, --font, .btn-p,
// .btn-s) geldiği için tek kod her iki markada da doğru görünür.

interface Slide {
  id: number;
  mirrorLayout: boolean;
  bgColor: string | null;
  bgImageUrl: string | null;
  bgImageOpacity: number | null;
  badgeText: string | null;
  headline: string | null;
  highlightWord: string | null;
  subtext: string | null;
  fgImageUrl: string | null;
  ctaPrimaryText: string | null;
  ctaPrimaryLink: string | null;
  ctaSecondaryText: string | null;
  ctaSecondaryLink: string | null;
  slideLink: string | null;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;

function splitHeadline(headline: string | null, highlight: string | null) {
  if (!headline) return null;
  if (!highlight || !headline.includes(highlight)) return { before: headline, hl: '', after: '' };
  const idx = headline.indexOf(highlight);
  return { before: headline.slice(0, idx), hl: highlight, after: headline.slice(idx + highlight.length) };
}
---

{slides.length > 0 && (
  <div class="hero-slider" data-count={slides.length}>
    {slides.map((s, i) => {
      const h = splitHeadline(s.headline, s.highlightWord);
      const hasCta = s.ctaPrimaryText || s.ctaSecondaryText;
      const wholeSlideClickable = !hasCta && s.slideLink;
      return (
        <div class={`hero-slide${i === 0 ? ' active' : ''}${wholeSlideClickable ? ' clickable' : ''}`} data-index={i} data-link={wholeSlideClickable ? s.slideLink : undefined}>
          <div class="hero-slide-bg" style={s.bgColor ? `background-color:${s.bgColor}` : undefined}>
            {s.bgImageUrl && <img class="hero-slide-bg-img" src={s.bgImageUrl} alt="" style={`opacity:${(s.bgImageOpacity ?? 100) / 100}`} />}
          </div>

          <div class={`hero-slide-in${s.mirrorLayout ? ' mirror' : ''}`}>
            <div class="hero-slide-text">
              {s.badgeText && (
                <div class="badge">
                  <span>{s.badgeText}</span>
                </div>
              )}
              {h && (
                <h1>
                  {h.before}{h.hl && <span>{h.hl}</span>}{h.after}
                </h1>
              )}
              {s.subtext && <p>{s.subtext}</p>}
              {hasCta && (
                <div class="hero-slide-ctas">
                  {s.ctaPrimaryText && <a href={s.ctaPrimaryLink || '#'} class="btn-p">{s.ctaPrimaryText}</a>}
                  {s.ctaSecondaryText && <a href={s.ctaSecondaryLink || '#'} target="_blank" rel="noopener" class="btn-s">{s.ctaSecondaryText}</a>}
                </div>
              )}
            </div>
            {s.fgImageUrl && (
              <div class="hero-slide-img">
                <img src={s.fgImageUrl} alt="" />
              </div>
            )}
          </div>
        </div>
      );
    })}

    {slides.length > 1 && (
      <div class="hero-dots">
        {slides.map((_, i) => (
          <button type="button" class={`hero-dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Slayt ${i + 1}`}></button>
        ))}
      </div>
    )}
  </div>
)}

<style>
  .hero-slider { position: relative; overflow: hidden; min-height: 420px; }
  .hero-slide { position: absolute; inset: 0; opacity: 0; visibility: hidden; transition: opacity .6s ease; }
  .hero-slide.active { position: relative; opacity: 1; visibility: visible; }
  .hero-slider[data-count="1"] .hero-slide { position: relative; }
  .hero-slide.clickable { cursor: pointer; }

  .hero-slide-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-slide-bg-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .hero-slide-in {
    position: relative; z-index: 1; max-width: 1140px; margin: 0 auto; padding: 64px 24px;
    display: grid; grid-template-columns: 1fr 320px; gap: 40px; align-items: center; min-height: 420px;
  }
  .hero-slide-in.mirror { grid-template-columns: 320px 1fr; }
  .hero-slide-in.mirror .hero-slide-text { order: 2; text-align: right; align-items: flex-end; }
  .hero-slide-in.mirror .hero-slide-img { order: 1; }
  .hero-slide-in.mirror .hero-slide-ctas { justify-content: flex-end; }

  .hero-slide-text { display: flex; flex-direction: column; align-items: flex-start; }
  .hero-slide-text .badge {
    display: inline-flex; align-items: center; gap: 8px; padding: 5px 12px; border-radius: 20px;
    background: rgba(var(--accent-rgb, 235,104,17), .15); border: 1px solid rgba(var(--accent-rgb, 235,104,17), .35);
    font-size: 12px; font-weight: 600; color: var(--accent-l, var(--accent)); letter-spacing: .05em; text-transform: uppercase; margin-bottom: 18px;
  }
  .hero-slide-text h1 { font-family: var(--cond); text-transform: uppercase; font-size: 34px; color: #fff; line-height: 1.2; margin-bottom: 14px; }
  .hero-slide-text h1 span { color: var(--accent); }
  .hero-slide-text p { font-size: 14.5px; color: rgba(255,255,255,.75); line-height: 1.7; margin-bottom: 26px; max-width: 480px; }
  .hero-slide-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-slide-img { display: flex; align-items: center; justify-content: center; }
  .hero-slide-img img { max-width: 300px; max-height: 300px; width: auto; height: auto; object-fit: contain; border-radius: 6px; box-shadow: 0 16px 48px rgba(0,0,0,.4); transform: rotate(1.5deg); }

  .hero-dots { position: absolute; left: 0; right: 0; bottom: 20px; z-index: 2; display: flex; justify-content: center; gap: 8px; }
  .hero-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,.35); border: none; padding: 0; cursor: pointer; transition: .2s; }
  .hero-dot.active { background: var(--accent); width: 22px; border-radius: 4px; }

  @media (max-width: 860px) {
    .hero-slider { min-height: 0; }
    .hero-slide-in { grid-template-columns: 1fr; padding: 32px 20px 56px; gap: 20px; min-height: 0; }
    .hero-slide-in.mirror { grid-template-columns: 1fr; }
    .hero-slide-in.mirror .hero-slide-text { text-align: left; align-items: flex-start; }
    .hero-slide-in.mirror .hero-slide-ctas { justify-content: flex-start; }
    .hero-slide-in.mirror .hero-slide-img,
    .hero-slide-in.mirror .hero-slide-text { order: initial; }
    .hero-slide-text h1 { font-size: 24px; }
    .hero-slide-img { order: -1; }
    .hero-slide-img img { max-height: 220px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.hero-slider').forEach((slider) => {
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('.hero-slide'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('.hero-dot'));

    slides.forEach((s) => {
      if (s.classList.contains('clickable')) {
        s.addEventListener('click', () => {
          const link = s.dataset.link;
          if (link) window.location.href = link;
        });
      }
    });

    if (slides.length <= 1) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function show(i: number) {
      slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
      dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
      current = i;
    }
    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(() => show((current + 1) % slides.length), 6000);
    }
    dots.forEach((d, idx) => {
      d.addEventListener('click', () => {
        show(idx);
        resetTimer();
      });
    });
    resetTimer();
  });
</script>
