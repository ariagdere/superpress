---
// src/pages/en/products/[...code].astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import ScrollToTopButton from '../../../components/ScrollToTopButton.astro';
import {
  getProduct,
  getProductSpecs,
  getProductDescription,
  getSpecialNote,
  getDrawing,
  getImages,
  getCertificates,
  getVariantTable,
  getCompatibleProducts,
  getRelatedProducts,
  getKunyeRanges,
  getKeyDocuments,
} from '../../../lib/queries.js';

import { env } from 'cloudflare:workers';
const lang = 'en';
const { code } = Astro.params;
const db = env.DB;

const product = await getProduct(db, code, lang);

if (!product) {
  return new Response('Product not found', { status: 404 });
}

// Bu ürünün TR karşılığı var mı? Yoksa dil switcher'ı "All Products"a düşsün, 404'e değil.
const trExists = await db.prepare("SELECT 1 FROM products WHERE prod_code = ? AND brand = 'Superpress' AND title_tr IS NOT NULL").bind(code).first();
const trSwitchOverride = trExists ? `/urunler/${code}` : '/kategori/';

const [specsRaw, description, specialNote, drawingUrl, images, certificates, compatible, related, keyDocs] = await Promise.all([
  getProductSpecs(db, product.id, lang),
  getProductDescription(db, product.id, lang),
  getSpecialNote(db, product.id, lang),
  getDrawing(db, product.drawing_ref),
  getImages(db, product.id),
  getCertificates(db, product.id),
  getCompatibleProducts(db, product.id, lang),
  getRelatedProducts(db, product.category_id, product.id, lang),
  getKeyDocuments(db, lang),
]);

let variantTable = { columns: [], rows: [] };
let kunyeRanges = [];
if (product.has_variant_table) {
  [variantTable, kunyeRanges] = await Promise.all([getVariantTable(db, product.id, lang), getKunyeRanges(db, product.id, lang)]);
}

const boyutCols = variantTable.columns.filter((c) => c.group_key === 'boyut');
const ekOzellikCols = variantTable.columns.filter((c) => c.group_key === 'ek_ozellik');
const adetAgirlikCols = variantTable.columns.filter((c) => c.group_key === 'adet_agirlik');
const kunyeFiltreCols = variantTable.columns.filter((c) => c.group_key === 'kunye_filtre');

// Filtre dropdown'ları: sadece birden fazla farklı değeri olan künye-filtre alanları için
const filterOptions = kunyeFiltreCols
  .map((col) => {
    const values = [...new Set(variantTable.rows.map((r) => r.values[col.attr_key]).filter(Boolean))];
    return { ...col, values };
  })
  .filter((f) => f.values.length > 1);

const displayCols = [...kunyeFiltreCols, ...boyutCols, ...ekOzellikCols, ...adetAgirlikCols];

// Masaüstü tablo başlığı gruplama: BOYUTLAR / KUTU / KOLİ çift satırlı grup başlıkları için
const kutuCols = adetAgirlikCols.filter((c) => c.attr_key === 'KUTU_ADEDI' || c.attr_key === 'KUTU_AGIRLIGI');
const koliCols = adetAgirlikCols.filter((c) => c.attr_key === 'KOLI_ADEDI' || c.attr_key === 'KOLI_AGIRLIGI');
const singleAdetCols = adetAgirlikCols.filter((c) => !['KUTU_ADEDI', 'KUTU_AGIRLIGI', 'KOLI_ADEDI', 'KOLI_AGIRLIGI'].includes(c.attr_key));
const subLabel = (c) => (c.attr_key.endsWith('ADEDI') ? 'Qty' : 'Weight');

const galleryImages = drawingUrl ? [...images, { file_url: drawingUrl, is_primary: 0, is_drawing: true }] : images;
const primaryImage = images.find((i) => i.is_primary) || images[0] || galleryImages[0];
const title = lang === 'en' ? product.title_en : product.title_tr;
const categoryName = lang === 'en' ? product.category_name_en : product.category_name_tr;
const certLine = certificates.map((c) => c.tag).join(' · ');

// Künye: TR/EN etiketleri çözülmüş, aralıklarla (Kablo Kesiti/Civata) birleştirilmiş liste
const specsResolved = specsRaw.map((s) => ({ attr_key: s.attr_key, label: lang === 'en' ? s.label_en : s.label_tr, value: s.value }));
const allSpecs = [...specsResolved.slice(0, 3), ...kunyeRanges, ...specsResolved.slice(3)];
const bySpecKey = Object.fromEntries(specsResolved.map((s) => [s.attr_key, s]));
const byRangeKey = Object.fromEntries(kunyeRanges.map((r) => [r.attr_key, r]));
const quickItems = [
  bySpecKey['MATERYAL'],
  bySpecKey['KAPLAMA'],
  byRangeKey['KABLO_KESITI'] && { label: lang === 'en' ? 'Section' : 'Kesit', value: byRangeKey['KABLO_KESITI'].value },
  byRangeKey['CIVATA'],
].filter(Boolean);

---
<Layout title={`${title} — Superpress`} lang={lang} trSwitchOverride={trSwitchOverride}>

<!-- ══════════ MASAÜSTÜ ══════════ -->
<div class="desktop-only">
  <div class="bc"><div class="bc-in">
    <a href="/en">Home</a><span>›</span>
    <a href={`/en/category/${product.category_slug}`}>Products</a><span>›</span>
    <a href={`/en/category/${product.category_slug}`}>{categoryName}</a><span>›</span>
    <span class="cur">{product.prod_code}</span>
  </div></div>

  <div class="prod-wrap"><div class="prod-in">
    <div class="prod-gallery">
      {primaryImage && (
        <div class="gallery-main" id="galleryMain">
          <img src={primaryImage.file_url} alt={title} id="galleryMainImg" data-full={primaryImage.file_url} />
          {certLine && <span class="gallery-badge">{certLine}</span>}
        </div>
      )}
      {galleryImages.length > 1 && (
        <div class="gallery-thumbs" id="galleryThumbs">
          {galleryImages.map((img, i) => (
            <img
              src={img.file_url}
              alt={img.is_drawing ? `${title} — Technical Drawing` : title}
              data-full={img.file_url}
              class={i === 0 ? 'active' : ''}
              style={`width:64px;height:64px;object-fit:contain;border-radius:6px;border:1px solid var(--g200);cursor:pointer${img.is_drawing ? ';background:var(--g50);padding:4px' : ''}`}
            />
          ))}
        </div>
      )}
    </div>

    <div class="prod-info">
      <div class="prod-cat">{categoryName}</div>
      <h1 class="prod-title">{title}</h1>
      <div class="prod-code">{product.prod_code}</div>

      {allSpecs.length > 0 && (
        <div class="prod-specs">
          {allSpecs.map((s) => (
            <div><div class="spec-lbl">{s.label}</div><div class="spec-val">{s.value}</div></div>
          ))}
        </div>
      )}

      {specialNote && <div class="special-note" style="background:#FFF8E6;border:1px solid #E0B341;border-radius:8px;padding:10px 14px;font-size:12.5px;color:#8a6d1f;margin-top:12px;margin-bottom:16px">{specialNote}</div>}

      <div class="prod-actions">
        <button type="button" id="btnAskDesktop" class="btn-ask"><svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15"><path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3Z" /><path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839Z" /></svg> Quote / Ask a Question</button>
        {keyDocs.catalogUrl && <a href={keyDocs.catalogUrl} target="_blank" rel="noopener" class="btn-cat"><svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15"><path fill-rule="evenodd" d="M4 4a2 2 0 0 1 2-2h4.586A2 2 0 0 1 12 2.586L15.414 6A2 2 0 0 1 16 7.414V16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4Zm2 6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H6Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H6Z" clip-rule="evenodd" /></svg> Catalog</a>}
        <a href="https://api.whatsapp.com/send/?phone=905303576490&text&app_absent=0" target="_blank" rel="noopener" class="btn-wp"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12.04 2c-5.52 0-10 4.48-10 10 0 1.77.46 3.45 1.27 4.9L2 22l5.25-1.38A9.96 9.96 0 0 0 12.04 22c5.52 0 10-4.48 10-10s-4.48-10-10-10Zm5.86 14.24c-.25.7-1.24 1.28-2.03 1.45-.55.11-1.26.2-3.67-.79-3.08-1.27-5.06-4.4-5.21-4.6-.15-.2-1.25-1.66-1.25-3.17s.79-2.25 1.07-2.56c.28-.31.61-.39.81-.39.2 0 .41 0 .59.01.19.01.44-.07.69.53.25.6.85 2.08.93 2.23.08.15.13.33.03.53-.1.2-.15.33-.3.5-.15.18-.31.4-.44.53-.15.15-.3.31-.13.61.17.3.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.36 1.46.3.15.48.13.65-.08.18-.2.75-.87.95-1.17.2-.3.4-.25.68-.15.28.1 1.76.83 2.06.98.3.15.5.23.57.35.08.13.08.75-.17 1.45Z"/></svg> WhatsApp</a>
      </div>

      {certificates.length > 0 && <div class="cert-row">{certificates.map((c) => <span class="cert-tag">{c.tag}</span>)}</div>}
    </div>
  </div></div>

  <div class="tabs-wrap">
    <div class="tabs-nav">
      {product.has_variant_table === 1 && <button class="tab-btn on" data-tab="tech">Technical Data</button>}
      {description && <button class={`tab-btn ${product.has_variant_table !== 1 ? 'on' : ''}`} data-tab="desc">Product Description</button>}
      <button class={`tab-btn ${product.has_variant_table !== 1 && !description ? 'on' : ''}`} data-tab="docs">Documents</button>
    </div>

    {product.has_variant_table === 1 && (
      <div id="tab-tech" class="tab-pane on">
        <div class="diag-area mode-fixed">
          {drawingUrl && <div class="diag-sticky-el"><img src={drawingUrl} alt="Technical Drawing" /><div class="diag-cap">Technical Reference Drawing</div></div>}
          <div class="diag-table-host">
            {filterOptions.length > 0 && (
              <div class="filter-row">
                <span class="filter-lbl">Filter:</span>
                {filterOptions.map((f) => (
                  <select class="filter-sel" data-filter-key={f.attr_key}>
                    <option value="">{`All ${f.label}`}</option>
                    {f.values.map((v) => <option value={v}>{v}</option>)}
                  </select>
                ))}
              </div>
            )}
            <div class="tbl-wrap">
              <table class="tbl" id="variantTbl">
                <thead>
                  <tr>
                    <th rowspan="2">Product Code</th>
                    {kunyeFiltreCols.map((c) => <th rowspan="2" style="text-align:right">{c.label}</th>)}
                    {boyutCols.length > 0 && <th colspan={boyutCols.length} style="text-align:center">Dimensions (mm)</th>}
                    {ekOzellikCols.map((c) => <th rowspan="2" style="text-align:right">{c.label}{c.unit ? ` (${c.unit})` : ''}</th>)}
                    {singleAdetCols.map((c) => <th rowspan="2" style="text-align:right">{c.label}</th>)}
                    {kutuCols.length > 0 && <th colspan={kutuCols.length} style="text-align:center">Box</th>}
                    {koliCols.length > 0 && <th colspan={koliCols.length} style="text-align:center">Case</th>}
                  </tr>
                  <tr>
                    {boyutCols.map((c) => <th style="text-align:right">{c.label}</th>)}
                    {kutuCols.map((c) => <th style="text-align:right">{subLabel(c)}</th>)}
                    {koliCols.map((c) => <th style="text-align:right">{subLabel(c)}</th>)}
                  </tr>
                </thead>
                <tbody>
                  {variantTable.rows.map((row, i) => (
                    <tr class={i % 2 === 1 ? 'alt' : ''} data-filters={JSON.stringify(Object.fromEntries(filterOptions.map((f) => [f.attr_key, row.values[f.attr_key] || ''])))}>
                      <td>{row.variant_code}</td>
                      {kunyeFiltreCols.map((c) => <td class="d">{row.values[c.attr_key] ?? '—'}</td>)}
                      {boyutCols.map((c) => <td class="d">{row.values[c.attr_key] ?? '—'}</td>)}
                      {ekOzellikCols.map((c) => <td class="d">{row.values[c.attr_key] ?? '—'}</td>)}
                      {singleAdetCols.map((c) => <td class="d">{row.values[c.attr_key] ?? '—'}</td>)}
                      {kutuCols.map((c) => <td class="d">{row.values[c.attr_key] ?? '—'}</td>)}
                      {koliCols.map((c) => <td class="d">{row.values[c.attr_key] ?? '—'}</td>)}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    )}

    {description && (
      <div id="tab-desc" class={`tab-pane ${product.has_variant_table !== 1 ? 'on' : ''}`}>
        <p style="font-size:15px;color:var(--g600);line-height:1.8;max-width:680px;white-space:pre-line">{description}</p>
      </div>
    )}

    <div id="tab-docs" class={`tab-pane ${product.has_variant_table !== 1 && !description ? 'on' : ''}`}>
      {certificates.length > 0 && (
        <div style="max-width:460px;margin-bottom:20px">
          <div style="font-size:12px;font-weight:700;color:var(--g400);text-transform:uppercase;letter-spacing:.04em;margin-bottom:9px">Product Certificates</div>
          <div style="display:flex;flex-direction:column;gap:9px">
            {certificates.map((c) => (c.file_url_tr || c.file_url_en) && (
              <a href={c.file_url_en || c.file_url_tr} target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:space-between;padding:11px 14px;background:var(--g50);border:1px solid var(--g200);border-radius:7px;text-decoration:none;color:var(--navy);font-size:13px;font-weight:600">
                <span style="display:flex;align-items:center;gap:8px"><svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 0 0 1.745-.723 3.066 3.066 0 0 1 3.976 0 3.066 3.066 0 0 0 1.745.723 3.066 3.066 0 0 1 2.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 0 1 0 3.976 3.066 3.066 0 0 0-.723 1.745 3.066 3.066 0 0 1-2.812 2.812 3.066 3.066 0 0 0-1.745.723 3.066 3.066 0 0 1-3.976 0 3.066 3.066 0 0 0-1.745-.723 3.066 3.066 0 0 1-2.812-2.812 3.066 3.066 0 0 0-.723-1.745 3.066 3.066 0 0 1 0-3.976 3.066 3.066 0 0 0 .723-1.745 3.066 3.066 0 0 1 2.812-2.812Zm7.44 5.252a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4Z" clip-rule="evenodd" /></svg>{c.name}</span>
                <span style="color:var(--blue);font-size:11px">↗</span>
              </a>
            ))}
          </div>
        </div>
      )}
      <div style="display:flex;flex-direction:column;gap:9px;max-width:460px" id="docsList">
        <p style="font-size:13px;color:var(--g400)">Loading…</p>
      </div>
    </div>
  </div>

  {compatible.length > 0 && (
    <div class="rel-sec"><div class="rel-in">
      <div class="rel-title">Compatible Products</div>
      <div class="cb-carousel">
        {compatible.map((c) => (
          <a href={`/en/products/${c.prod_code}`} class="cb-card">
            <div class="cb-card-img">{c.image && <img src={c.image} alt={c.title} />}</div>
            <div class="cb-card-body">
              <div class="cb-card-code">{c.prod_code}</div>
              <div class="cb-card-name">{c.title}</div>
              {(c.kesitRange || c.civataRange) && (
                <div class="cb-card-specs">
                  {c.kesitRange && <div class="cb-card-spec">Cross-section: <b>{c.kesitRange} mm²</b></div>}
                  {c.civataRange && <div class="cb-card-spec">Bolt: <b>{c.civataRange}</b></div>}
                </div>
              )}
              <span class="cb-card-cta">Technical data →</span>
            </div>
          </a>
        ))}
      </div>
    </div></div>
  )}

  {related.length > 0 && (
    <div class="rel-sec"><div class="rel-in">
      <div class="rel-title">Other Products in This Category</div>
      <div class="cb-carousel">
        {related.map((r) => (
          <a href={`/en/products/${r.prod_code}`} class="cb-card">
            <div class="cb-card-img">{r.image && <img src={r.image} alt={r.title} />}</div>
            <div class="cb-card-body">
              <div class="cb-card-code">{r.prod_code}</div>
              <div class="cb-card-name">{r.title}</div>
              {(r.kesitRange || r.civataRange) && (
                <div class="cb-card-specs">
                  {r.kesitRange && <div class="cb-card-spec">Cross-section: <b>{r.kesitRange} mm²</b></div>}
                  {r.civataRange && <div class="cb-card-spec">Bolt: <b>{r.civataRange}</b></div>}
                </div>
              )}
              <span class="cb-card-cta">Technical data →</span>
            </div>
          </a>
        ))}
      </div>
    </div></div>
  )}
</div>

<!-- ══════════ MOBİL ══════════ -->
<div class="mobile-only">
  <div class="m-bc">
    <a href="/en">Home</a><span>›</span>
    <a href={`/en/category/${product.category_slug}`}>Products</a><span>›</span>
    <a href={`/en/category/${product.category_slug}`}>{categoryName}</a><span>›</span>
    <span style="color:var(--g800)">{product.prod_code}</span>
  </div>

  <div class="m-prod-gal">
    <div class="m-gal-main" id="mGalleryMain">
      {primaryImage && <img src={primaryImage.file_url} alt={title} id="mGalleryMainImg" data-full={primaryImage.file_url} />}
      {certLine && <span class="m-gal-badge">{certLine}</span>}
    </div>
    {galleryImages.length > 1 && (
      <div class="m-gal-thumbs" id="mGalleryThumbs">
        {galleryImages.map((img, i) => (
          <img src={img.file_url} alt={img.is_drawing ? `${title} — Technical Drawing` : title} data-full={img.file_url} class={i === 0 ? 'active' : ''} />
        ))}
      </div>
    )}
  </div>

  <div class="m-prod-info">
    <div class="m-prod-cat">{categoryName}</div>
    <h1 class="m-prod-title">{title}</h1>
    <div class="m-prod-code">{product.prod_code}</div>

    {quickItems.length > 0 && (
      <div class="m-quick">
        {quickItems.map((q) => <div><div class="m-quick-lbl">{q.label}</div><div class="m-quick-val">{q.value}</div></div>)}
      </div>
    )}

    {specialNote && <div class="special-note" style="background:#FFF8E6;border:1px solid #E0B341;border-radius:8px;padding:10px 14px;font-size:12.5px;color:#8a6d1f;margin-bottom:12px">{specialNote}</div>}

    <div class="m-prod-btns">
      <button type="button" id="btnAskMobile" class="m-btn-ask"><svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3Z" /><path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839Z" /></svg> Quote / Ask a Question</button>
      <div class="m-btn-row">{keyDocs.catalogUrl && <a href={keyDocs.catalogUrl} target="_blank" rel="noopener" class="m-btn-cat"><svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M4 4a2 2 0 0 1 2-2h4.586A2 2 0 0 1 12 2.586L15.414 6A2 2 0 0 1 16 7.414V16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4Zm2 6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H6Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H6Z" clip-rule="evenodd" /></svg> Catalog</a>}<a href="https://api.whatsapp.com/send/?phone=905303576490&text&app_absent=0" target="_blank" rel="noopener" class="m-btn-wp"><svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12.04 2c-5.52 0-10 4.48-10 10 0 1.77.46 3.45 1.27 4.9L2 22l5.25-1.38A9.96 9.96 0 0 0 12.04 22c5.52 0 10-4.48 10-10s-4.48-10-10-10Zm5.86 14.24c-.25.7-1.24 1.28-2.03 1.45-.55.11-1.26.2-3.67-.79-3.08-1.27-5.06-4.4-5.21-4.6-.15-.2-1.25-1.66-1.25-3.17s.79-2.25 1.07-2.56c.28-.31.61-.39.81-.39.2 0 .41 0 .59.01.19.01.44-.07.69.53.25.6.85 2.08.93 2.23.08.15.13.33.03.53-.1.2-.15.33-.3.5-.15.18-.31.4-.44.53-.15.15-.3.31-.13.61.17.3.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.36 1.46.3.15.48.13.65-.08.18-.2.75-.87.95-1.17.2-.3.4-.25.68-.15.28.1 1.76.83 2.06.98.3.15.5.23.57.35.08.13.08.75-.17 1.45Z"/></svg> WhatsApp</a></div>
    </div>
  </div>

  <div class="m-tabs">
    {product.has_variant_table === 1 && <button class="m-tab on" id="mTabBtnTech" data-mtab="mtech">Technical Data</button>}
    {description && <button class={`m-tab ${product.has_variant_table !== 1 ? 'on' : ''}`} data-mtab="mdesc">Description</button>}
    <button class={`m-tab ${product.has_variant_table !== 1 && !description ? 'on' : ''}`} data-mtab="mdocs">Documents</button>
  </div>

  {product.has_variant_table === 1 && (
    <div id="mtech" class="m-tab-pane on">
      <div class="m-tbl-sec">
        <div class="diag-area mode-fixed" id="mDiagArea">
          {drawingUrl && <div class="diag-sticky-el" id="mDiagSticky"><img src={drawingUrl} alt="Technical Drawing" /><div class="diag-cap">Technical Reference Drawing</div></div>}
          <div class="diag-table-host">
            {filterOptions.length > 0 && (
              <div class="m-filter-row">
                {filterOptions.map((f) => (
                  <select class="m-filter-sel" data-mfilter-key={f.attr_key}>
                    <option value="">{`All ${f.label}`}</option>
                    {f.values.map((v) => <option value={v}>{v}</option>)}
                  </select>
                ))}
              </div>
            )}
            <div id="mVariantCards">
            {variantTable.rows.map((row) => (
              <div class="row-card" data-mfilters={JSON.stringify(Object.fromEntries(filterOptions.map((f) => [f.attr_key, row.values[f.attr_key] || ''])))}>
                <div class="rc-hdr">
                  <span class="rc-code">{row.variant_code}</span>
                  {kunyeFiltreCols.some((c) => row.values[c.attr_key]) && (
                    <span class="rc-bolt">{kunyeFiltreCols.map((c) => (row.values[c.attr_key] ? `${row.values[c.attr_key]}${c.unit ? ` ${c.unit}` : ''}` : null)).filter(Boolean).join(' · ')}</span>
                  )}
                </div>
                <div class="rc-dims">
                  {[...boyutCols, ...ekOzellikCols].map((c) => (
                    <div class="rc-dim"><div class="rc-dim-l">{c.label}</div><div class="rc-dim-v">{row.values[c.attr_key] ?? '—'}</div></div>
                  ))}
                </div>
                {(row.values['KUTU_ADEDI'] || row.values['KOLI_ADEDI'] || row.values['PAKET_ADEDI'] || row.values['POSET_ADEDI'] || row.values['CUVAL_ADEDI']) && (
                  <div class="rc-pkg">
                    {row.values['PAKET_ADEDI'] && <span>Pack: <strong>{row.values['PAKET_ADEDI']} pcs</strong></span>}
                    {row.values['POSET_ADEDI'] && <span>Bag: <strong>{row.values['POSET_ADEDI']} pcs</strong></span>}
                    {row.values['CUVAL_ADEDI'] && <span>Sack: <strong>{row.values['CUVAL_ADEDI']} pcs</strong></span>}
                    {row.values['KUTU_ADEDI'] && <span>Box: <strong>{row.values['KUTU_ADEDI']} pcs{row.values['KUTU_AGIRLIGI'] ? ` · ${row.values['KUTU_AGIRLIGI']}` : ''}</strong></span>}
                    {row.values['KOLI_ADEDI'] && <span>Case: <strong>{row.values['KOLI_ADEDI']}{row.values['KOLI_AGIRLIGI'] ? ` · ${row.values['KOLI_AGIRLIGI']}` : ''}</strong></span>}
                  </div>
                )}
              </div>
            ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  {description && (
    <div id="mdesc" class={`m-tab-pane ${product.has_variant_table !== 1 ? 'on' : ''}`}>
      <div style="padding:16px;font-size:13px;color:var(--g600);line-height:1.75;white-space:pre-line">{description}</div>
    </div>
  )}

  <div id="mdocs" class={`m-tab-pane ${product.has_variant_table !== 1 && !description ? 'on' : ''}`}>
    {certificates.length > 0 && (
      <div style="padding:14px 16px 0">
        <div style="font-size:11px;font-weight:700;color:var(--g400);text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px">Product Certificates</div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:6px">
          {certificates.map((c) => (c.file_url_tr || c.file_url_en) && (
            <a href={c.file_url_en || c.file_url_tr} target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:space-between;padding:11px 13px;background:var(--g50);border:1px solid var(--g200);border-radius:7px;text-decoration:none;color:var(--navy);font-size:13px;font-weight:600">
              <span style="display:flex;align-items:center;gap:8px"><svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 0 0 1.745-.723 3.066 3.066 0 0 1 3.976 0 3.066 3.066 0 0 0 1.745.723 3.066 3.066 0 0 1 2.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 0 1 0 3.976 3.066 3.066 0 0 0-.723 1.745 3.066 3.066 0 0 1-2.812 2.812 3.066 3.066 0 0 0-1.745.723 3.066 3.066 0 0 1-3.976 0 3.066 3.066 0 0 0-1.745-.723 3.066 3.066 0 0 1-2.812-2.812 3.066 3.066 0 0 0-.723-1.745 3.066 3.066 0 0 1 0-3.976 3.066 3.066 0 0 0 .723-1.745 3.066 3.066 0 0 1 2.812-2.812Zm7.44 5.252a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4Z" clip-rule="evenodd" /></svg>{c.name}</span>
              <span style="color:var(--blue);font-size:11px">↗</span>
            </a>
          ))}
        </div>
      </div>
    )}
    <div style="padding:14px 16px;display:flex;flex-direction:column;gap:8px" id="mDocsList">
      <p style="font-size:13px;color:var(--g400)">Loading…</p>
    </div>
  </div>

  {compatible.length > 0 && (
    <div class="m-rel">
      <div class="m-rel-title">Compatible Products</div>
      <div class="m-cb-carousel-wrap">
      <div class="m-cb-carousel">
        {compatible.map((c) => (
          <a href={`/en/products/${c.prod_code}`} class="m-cb-card">
            <div class="m-cb-img">{c.image && <img src={c.image} alt={c.title} />}</div>
            <div class="m-cb-body2">
              <div class="m-cb-code">{c.prod_code}</div>
              <div class="m-cb-name">{c.title}</div>
              {(c.kesitRange || c.civataRange) && (
                <div class="m-cb-spec">
                  {c.kesitRange && <>Cross-section: <b>{c.kesitRange} mm²</b></>}
                  {c.kesitRange && c.civataRange && ' · '}
                  {c.civataRange && <>Bolt: <b>{c.civataRange}</b></>}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
      {compatible.length > 2 && <div class="m-cb-scroll-hint">›</div>}
      </div>
    </div>
  )}

  {related.length > 0 && (
    <div class="m-rel">
      <div class="m-rel-title">Other Products in This Category</div>
      <div class="m-cb-carousel-wrap">
      <div class="m-cb-carousel">
        {related.map((r) => (
          <a href={`/en/products/${r.prod_code}`} class="m-cb-card">
            <div class="m-cb-img">{r.image && <img src={r.image} alt={r.title} />}</div>
            <div class="m-cb-body2">
              <div class="m-cb-code">{r.prod_code}</div>
              <div class="m-cb-name">{r.title}</div>
              {(r.kesitRange || r.civataRange) && (
                <div class="m-cb-spec">
                  {r.kesitRange && <>Cross-section: <b>{r.kesitRange} mm²</b></>}
                  {r.kesitRange && r.civataRange && ' · '}
                  {r.civataRange && <>Bolt: <b>{r.civataRange}</b></>}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
      {related.length > 2 && <div class="m-cb-scroll-hint">›</div>}
      </div>
    </div>
  )}
  <ScrollToTopButton />
</div>
<div class="img-lightbox" id="imgLightbox">
  <button class="img-lightbox-close" id="imgLightboxClose">✕</button>
  <img src="" alt="" id="imgLightboxImg" />
</div>

<div class="quote-modal" id="quoteModal">
  <div class="quote-modal-card">
    <button type="button" class="quote-modal-close" id="quoteModalClose" aria-label="Close">✕</button>
    <h3 class="quote-modal-title">Quote / Ask a Question</h3>
    <p class="quote-modal-product">Product: <strong id="quoteModalProduct"></strong></p>

    <div id="quoteSuccess" style="display:none;background:#eafaf0;border:1px solid #a7e3bd;color:#1e7a46;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:13.5px">
      Your request has been received, thank you. We'll get back to you shortly.
    </div>
    <div id="quoteError" style="display:none;background:#fdecec;border:1px solid #f0b3b3;color:#a32020;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:13.5px"></div>

    <form id="quoteForm">
      <div>
        <label class="cf-lbl">Full Name *</label>
        <input type="text" name="name" required class="cf-input" />
      </div>
      <div>
        <label class="cf-lbl">Email *</label>
        <input type="email" name="email" required class="cf-input" />
      </div>
      <div>
        <label class="cf-lbl">Phone</label>
        <input type="tel" name="phone" class="cf-input" />
      </div>
      <div>
        <label class="cf-lbl">Your Message</label>
        <textarea name="message" rows="4" class="cf-input" style="resize:vertical"></textarea>
      </div>
      <div class="cf-turnstile" data-sitekey="0x4AAAAAADzH9tbdF9k28nV8"></div>
      <button type="submit" id="quoteSubmit" class="btn-p" style="width:100%;border:none;cursor:pointer;margin-top:4px">Send</button>
    </form>
  </div>
</div>
</Layout>

<style>
  .quote-modal{position:fixed;inset:0;background:rgba(10,20,35,.6);z-index:6000;display:none;align-items:center;justify-content:center;padding:20px}
  .quote-modal.open{display:flex}
  .quote-modal-card{background:#fff;border-radius:10px;max-width:460px;width:100%;max-height:88vh;overflow-y:auto;padding:26px;position:relative}
  .quote-modal-close{position:absolute;top:14px;right:14px;width:30px;height:30px;border-radius:50%;background:var(--g50);border:none;color:var(--g600);font-size:14px;cursor:pointer}
  .quote-modal-title{font-family:var(--cond);text-transform:uppercase;font-size:21px;color:var(--navy);margin-bottom:4px}
  .quote-modal-product{font-size:13.5px;color:var(--g600);margin-bottom:18px}
  #quoteForm{display:flex;flex-direction:column;gap:14px}
  .cf-lbl{display:block;font-size:12.5px;font-weight:600;color:var(--navy);margin-bottom:6px}
  .cf-input{width:100%;padding:10px 12px;border:1px solid var(--g200);border-radius:6px;font-size:14px;font-family:var(--font);color:var(--g800);background:#fff}
  .cf-input:focus{outline:none;border-color:var(--blue)}
  @media (max-width:860px){
    .cf-input{font-size:16px}
  }
</style>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script define:vars={{ productBrand: product.brand || '', pageLang: lang, productTitle: title, productCode: product.prod_code }}>
  // Masaüstü sekme geçişi
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('on'));
      document.querySelectorAll('.desktop-only .tab-pane').forEach((p) => p.classList.remove('on'));
      btn.classList.add('on');
      const pane = document.getElementById('tab-' + btn.dataset.tab);
      if (pane) pane.classList.add('on');
    });
  });

  // Mobil sekme geçişi
  document.querySelectorAll('.m-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.m-tab').forEach((b) => b.classList.remove('on'));
      document.querySelectorAll('.m-tab-pane').forEach((p) => p.classList.remove('on'));
      btn.classList.add('on');
      const pane = document.getElementById(btn.dataset.mtab);
      if (pane) pane.classList.add('on');
    });
  });

  // Varyant tablosu filtreleme (masaüstü)
  document.querySelectorAll('.filter-sel').forEach((sel) => {
    sel.addEventListener('change', () => {
      const active = {};
      document.querySelectorAll('.filter-sel').forEach((s) => {
        if (s.value) active[s.dataset.filterKey] = s.value;
      });
      document.querySelectorAll('#variantTbl tbody tr').forEach((tr) => {
        const rowFilters = JSON.parse(tr.dataset.filters || '{}');
        const match = Object.entries(active).every(([k, v]) => rowFilters[k] === v);
        tr.style.display = match ? '' : 'none';
      });
    });
  });

  // Varyant kartları filtreleme (mobil)
  document.querySelectorAll('.m-filter-sel').forEach((sel) => {
    sel.addEventListener('change', () => {
      const active = {};
      document.querySelectorAll('.m-filter-sel').forEach((s) => {
        if (s.value) active[s.dataset.mfilterKey] = s.value;
      });
      document.querySelectorAll('#mVariantCards .row-card').forEach((card) => {
        const rowFilters = JSON.parse(card.dataset.mfilters || '{}');
        const match = Object.entries(active).every(([k, v]) => rowFilters[k] === v);
        card.style.display = match ? '' : 'none';
      });
    });
  });

  // Galeri: küçük resme tıklayınca büyük resmi (hem masaüstü hem mobil) değiştir
  function setActiveThumb(container, clicked) {
    container.querySelectorAll('img').forEach((i) => i.classList.remove('active'));
    clicked.classList.add('active');
  }
  document.querySelectorAll('#galleryThumbs img').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const full = thumb.dataset.full;
      const dMain = document.getElementById('galleryMainImg');
      const mMain = document.getElementById('mGalleryMainImg');
      if (dMain) dMain.src = full;
      if (mMain) mMain.src = full;
      setActiveThumb(document.getElementById('galleryThumbs'), thumb);
      const mThumb = document.querySelector(`#mGalleryThumbs img[data-full="${full}"]`);
      if (mThumb) setActiveThumb(document.getElementById('mGalleryThumbs'), mThumb);
    });
  });
  document.querySelectorAll('#mGalleryThumbs img').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const full = thumb.dataset.full;
      const dMain = document.getElementById('galleryMainImg');
      const mMain = document.getElementById('mGalleryMainImg');
      if (dMain) dMain.src = full;
      if (mMain) mMain.src = full;
      setActiveThumb(document.getElementById('mGalleryThumbs'), thumb);
      const dThumb = document.querySelector(`#galleryThumbs img[data-full="${full}"]`);
      if (dThumb) setActiveThumb(document.getElementById('galleryThumbs'), dThumb);
    });
  });

  // Galeri: büyük resme (ya da teknik çizime) tıklayınca lightbox aç
  const lightbox = document.getElementById('imgLightbox');
  const lightboxImg = document.getElementById('imgLightboxImg');
  function openLightbox(src, alt) {
    lightboxImg.src = src;
    lightboxImg.alt = alt || '';
    lightbox.classList.add('open');
  }
  document.getElementById('galleryMain')?.addEventListener('click', () => {
    const img = document.getElementById('galleryMainImg');
    openLightbox(img.src, img.alt);
  });
  document.getElementById('mGalleryMain')?.addEventListener('click', () => {
    const img = document.getElementById('mGalleryMainImg');
    openLightbox(img.src, img.alt);
  });
  document.querySelectorAll('.diag-sticky-el img').forEach((img) => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });
  document.getElementById('imgLightboxClose')?.addEventListener('click', () => lightbox.classList.remove('open'));
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) lightbox.classList.remove('open');
  });

  // Belgeler: markaya göre filtrelenmiş dokümanları API'den çek, hem masaüstü hem mobil listeye yaz
  fetch('/api/documents?brand=' + encodeURIComponent(productBrand) + '&lang=' + encodeURIComponent(pageLang))
    .then((r) => r.json())
    .then((docs) => {
      const html = !docs.length
        ? '<p style="font-size:13px;color:var(--g400)">No documents found.</p>'
        : docs
            .map(
              (d) =>
                `<a href="${d.file_url_tr || d.file_url_en}" ${d.doc_type === 'fiyat_listesi' ? 'download' : 'target="_blank" rel="noopener"'} style="display:flex;align-items:center;justify-content:space-between;padding:11px 14px;background:var(--g50);border:1px solid var(--g200);border-radius:7px;text-decoration:none;color:var(--navy);font-size:13px;font-weight:600"><span style="display:flex;align-items:center;gap:8px"><svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M4 4a2 2 0 0 1 2-2h4.586A2 2 0 0 1 12 2.586L15.414 6A2 2 0 0 1 16 7.414V16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4Zm2 6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H6Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H6Z" clip-rule="evenodd" /></svg>${d.title_en || d.title_tr}</span><span style="color:var(--blue);font-size:11px">${d.doc_type === 'fiyat_listesi' ? '↓' : '↗'}</span></a>`
            )
            .join('');
      const desktopList = document.getElementById('docsList');
      const mobileList = document.getElementById('mDocsList');
      if (desktopList) desktopList.innerHTML = html;
      if (mobileList) mobileList.innerHTML = html;
    })
    .catch(() => {});

  // Teklif / Soru Sor modalı
  const quoteModal = document.getElementById('quoteModal');
  const quoteModalProduct = document.getElementById('quoteModalProduct');
  const quoteForm = document.getElementById('quoteForm');
  const quoteSuccess = document.getElementById('quoteSuccess');
  const quoteError = document.getElementById('quoteError');
  const quoteSubmit = document.getElementById('quoteSubmit');

  function resetMobileZoom() {
    const viewport = document.querySelector('meta[name="viewport"]');
    if (!viewport) return;
    const original = viewport.getAttribute('content');
    viewport.setAttribute('content', original + ', maximum-scale=1.0');
    setTimeout(() => viewport.setAttribute('content', original), 350);
  }

  function openQuoteModal() {
    quoteModalProduct.textContent = productTitle;
    quoteSuccess.style.display = 'none';
    quoteError.style.display = 'none';
    quoteModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeQuoteModal() {
    quoteModal.classList.remove('open');
    document.body.style.overflow = '';
    resetMobileZoom();
  }

  document.getElementById('btnAskDesktop')?.addEventListener('click', openQuoteModal);
  document.getElementById('btnAskMobile')?.addEventListener('click', openQuoteModal);
  document.getElementById('quoteModalClose')?.addEventListener('click', closeQuoteModal);
  quoteModal?.addEventListener('click', (e) => {
    if (e.target === quoteModal) closeQuoteModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && quoteModal.classList.contains('open')) closeQuoteModal();
  });

  quoteForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    quoteSuccess.style.display = 'none';
    quoteError.style.display = 'none';

    const formData = new FormData(quoteForm);
    const payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      product: productTitle,
      message: formData.get('message'),
      turnstileToken: formData.get('cf-turnstile-response'),
      lang: 'en',
    };

    quoteSubmit.disabled = true;
    quoteSubmit.textContent = 'Sending…';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Something went wrong.');
      quoteSuccess.style.display = 'block';
      quoteForm.reset();
      if (window.turnstile) window.turnstile.reset();
    } catch (err) {
      quoteError.textContent = err.message || 'Something went wrong, please try again.';
      quoteError.style.display = 'block';
      if (window.turnstile) window.turnstile.reset();
    } finally {
      quoteSubmit.disabled = false;
      quoteSubmit.textContent = 'Send';
    }
  });
</script>
