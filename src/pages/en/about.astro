---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getPageSection } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'en';
const [anaMetin, kalitePolitikasi] = await Promise.all([
  getPageSection(env.DB, 'hakkimizda', 'ana_metin', lang),
  getPageSection(env.DB, 'hakkimizda', 'kalite_politikasi', lang),
]);
---
<Layout title="About — Superpress" lang={lang}>
  <div class="desktop-only">
    <div class="bc"><div class="bc-in"><a href="/en">Home</a><span>›</span><span class="cur">About</span></div></div>
  </div>
  <div class="mobile-only">
    <div class="m-bc"><a href="/en">Home</a><span>›</span><span style="color:var(--g800)">About</span></div>
  </div>

  <div class="sec"><div class="sec-in" style="max-width:820px">
    <h1 style="font-family:var(--cond);text-transform:uppercase;font-size:28px;color:var(--navy);margin-bottom:20px">About</h1>
    <div class="ana-metin">
      <Fragment set:html={anaMetin} />
    </div>
  </div></div>

  <div class="sec" style="background:var(--g50)"><div class="sec-in" style="max-width:820px">
    <h2 style="font-family:var(--cond);text-transform:uppercase;font-size:26px;color:var(--navy);margin-bottom:20px">Our Quality Policy</h2>
    <div class="kalite-text">
      <Fragment set:html={kalitePolitikasi} />
    </div>
  </div></div>

<style>
  .ana-metin p { font-size: 14.5px; color: var(--g600); line-height: 1.9; margin-bottom: 18px; }
  .ana-metin p:last-child { margin-bottom: 0; }
  .kalite-text p { font-size: 14.5px; color: var(--g600); line-height: 1.85; margin-bottom: 14px; }
  .kalite-text ul { list-style: none; padding: 0; margin: 0 0 16px 0; display: flex; flex-direction: column; gap: 10px; }
  .kalite-text li { position: relative; padding-left: 22px; font-size: 14.5px; color: var(--g600); line-height: 1.7; }
  .kalite-text li::before { content: '✓'; position: absolute; left: 0; top: 0; color: var(--blue); font-weight: 700; }
</style>
</Layout>
