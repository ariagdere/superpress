---
// src/pages/en/index.astro
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getCategoriesWithCounts, getKeyDocuments } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'en';
const db = env.DB;

const [categories, keyDocs] = await Promise.all([getCategoriesWithCounts(db, lang), getKeyDocuments(db, lang)]);
---
<Layout title="SUPERPRESS" lang={lang}>

<!-- ══════════ DESKTOP ══════════ -->
<div class="desktop-only">
  <div class="hero"><div class="hero-in">
    <div class="hero-l">
      <div class="badge">A Simpa Elektrik Subsidiary</div>
      <h1>Professional Hand Tools <span>for Cable Assembly</span></h1>
      <p>Cable cutters, mechanical and hydraulic crimping pliers — assembly-ready solutions fully compatible with the cable lugs manufactured by Simpa Elektrik.</p>
      <div class="hero-btns">
        <a href="/en/category/" class="btn-p">Browse Products →</a>
        <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="btn-s"><svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15"><path fill-rule="evenodd" d="M4 4a2 2 0 0 1 2-2h4.586A2 2 0 0 1 12 2.586L15.414 6A2 2 0 0 1 16 7.414V16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4Zm2 6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H6Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H6Z" clip-rule="evenodd" /></svg> Download Catalog</a>
      </div>
    </div>
    <div class="hero-r">
      <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener">
        <img src="https://assets.superpress.com.tr/superpressktalogkutuSAG1.png" alt="Superpress Product Catalog" />
      </a>
    </div>
  </div></div>

  <div class="sec"><div class="sec-in" style="max-width:900px;text-align:center">
    <div class="about-lbl" style="color:var(--blue)">About Us</div>
    <h2 style="font-family:var(--cond);text-transform:uppercase;font-size:28px;color:var(--navy);margin:10px 0 18px">Cable Hand Tool Experts, Under the Simpa Elektrik Umbrella</h2>
    <p style="font-size:14.5px;color:var(--g600);line-height:1.85;max-width:720px;margin:0 auto 22px">
      Superpress was established in 2023 as a subsidiary of Simpa Elektrik, to manufacture mechanical, hydraulic,
      and electric hand tools used in the process of cutting electrical cables and compressing cable lugs to
      prepare them for assembly. Crimping pliers fully compatible with the cable lugs manufactured under Simpa
      Elektrik form the foundation of our products.
    </p>
    <a href="/en/about" class="btn-p" style="display:inline-block">Learn More →</a>
  </div></div>

  <div class="sec" style="background:var(--g50)"><div class="sec-in">
    <div class="sec-hdr">
      <div><a href="/en/category/" class="sec-title title-link">Product <span>Groups</span></a><div class="sec-sub">Choose the cable hand tool that fits your needs</div></div>
    </div>
    <div class="groups-grid">
      {categories.map((c) => (
        <a href={`/en/category/${c.slug}`} class="group-card">
          <div class="group-card-img">{c.image_url && <img src={c.image_url} alt={c.name} />}</div>
          <div class="group-card-body"><div class="group-card-name">{c.name}</div><div class="group-card-sub">{c.product_count} series</div></div>
        </a>
      ))}
    </div>
  </div></div>
</div>

<!-- ══════════ MOBILE ══════════ -->
<div class="mobile-only">
  <div class="m-hero">
    <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener">
      <img class="m-hero-img" src="https://assets.superpress.com.tr/superpressktalogkutuSAG1.png" alt="Superpress Product Catalog" />
    </a>
    <div class="m-hero-body">
      <div class="m-badge">A Simpa Elektrik Subsidiary</div>
      <h1>Professional Hand Tools <span>for Cable Assembly</span></h1>
      <p>Cable cutters, mechanical and hydraulic crimping pliers — assembly-ready solutions.</p>
      <div class="m-hero-btns"><a href="/en/category/" class="m-btn-p">Browse Products</a><a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="m-btn-s">Catalog</a></div>
    </div>
  </div>

  <div class="m-sec">
    <div style="text-align:center;padding:8px 4px 20px">
      <div class="m-about-lbl" style="color:var(--blue)">About Us</div>
      <h2 style="font-family:var(--cond);text-transform:uppercase;font-size:20px;color:var(--navy);margin:8px 0 12px">Cable Hand Tool Experts</h2>
      <p style="font-size:13.5px;color:var(--g600);line-height:1.8;margin-bottom:16px">
        Superpress was established in 2023 as a subsidiary of Simpa Elektrik. Crimping pliers fully compatible
        with the cable lugs manufactured under Simpa Elektrik form the foundation of our products.
      </p>
      <a href="/en/about" class="m-btn-p" style="display:inline-block">Learn More →</a>
    </div>
  </div>

  <div class="m-sec" style="background:var(--g50)">
    <a href="/en/category/" class="title-link" style="display:block"><h2 style="font-family:var(--cond);text-transform:uppercase;font-size:20px;color:var(--navy);margin-bottom:14px">Product Groups</h2></a>
    <div class="m-groups-grid">
      {categories.map((c) => (
        <a href={`/en/category/${c.slug}`} class="m-group-card">
          <div class="m-group-card-img">{c.image_url && <img src={c.image_url} alt={c.name} />}</div>
          <div class="m-group-card-body"><div class="m-group-card-name">{c.name}</div><div class="m-group-card-sub">{c.product_count} series</div></div>
        </a>
      ))}
    </div>
  </div>
</div>
</Layout>
