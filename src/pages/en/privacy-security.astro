---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getPageSection } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'en';
const gizlilikMetni = await getPageSection(env.DB, 'gizlilik-ve-guvenlik', 'gizlilik_metni', lang);
---
<Layout title="Privacy & Security — Superpress" lang={lang}>
  <div class="desktop-only">
    <div class="bc"><div class="bc-in"><a href="/en">Home</a><span>›</span><span class="cur">Privacy & Security</span></div></div>
  </div>
  <div class="mobile-only">
    <div class="m-bc"><a href="/en">Home</a><span>›</span><span style="color:var(--g800)">Privacy & Security</span></div>
  </div>

  <div class="sec"><div class="sec-in" style="max-width:820px">
    <h1 style="font-family:var(--cond);text-transform:uppercase;font-size:28px;color:var(--navy);margin-bottom:6px">Privacy & Security</h1>
    <div class="legal-updated">Last updated: July 2026</div>

    <div class="legal-content">
      <Fragment set:html={gizlilikMetni} />
    </div>
  </div></div>
</Layout>

<style>
  .legal-updated { font-size: 12.5px; color: var(--g400); margin-bottom: 20px; }
  .legal-content h2 { font-family: var(--cond);text-transform:uppercase; font-size: 20px; color: var(--navy); margin-top: 28px; margin-bottom: 12px; }
  .legal-content p { font-size: 14px; color: var(--g600); line-height: 1.85; margin-bottom: 14px; }
  .legal-content strong { color: var(--g800); }
  .legal-content a { color: var(--blue); text-decoration: none; }
  .legal-content ul { list-style: none; padding: 0; margin: 0 0 14px 0; display: flex; flex-direction: column; gap: 8px; }
  .legal-content li { position: relative; padding-left: 18px; font-size: 14px; color: var(--g600); line-height: 1.7; }
  .legal-content li::before { content: '•'; position: absolute; left: 0; color: var(--blue); font-weight: 700; }
</style>
