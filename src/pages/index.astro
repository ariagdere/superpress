---
// src/pages/index.astro
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import { getCategoriesWithCounts, getKeyDocuments, getActiveHeroSlides } from '../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'tr';
const db = env.DB;

const [categories, keyDocs, heroSlides] = await Promise.all([
  getCategoriesWithCounts(db, lang),
  getKeyDocuments(db, lang),
  getActiveHeroSlides(db, lang),
]);
---
<Layout title="SUPERPRESS" lang={lang}>

<HeroSlider slides={heroSlides} />

<!-- ══════════ DESKTOP ══════════ -->
<div class="desktop-only">
  <div class="sec"><div class="sec-in" style="max-width:900px;text-align:center">
    <div class="about-lbl" style="color:var(--blue)">Hakkımızda</div>
    <h2 style="font-family:var(--cond);text-transform:uppercase;font-size:28px;color:var(--navy);margin:10px 0 18px">Simpa Elektrik Çatısı Altında, Kablo El Aletlerinde Uzman</h2>
    <p style="font-size:14.5px;color:var(--g600);line-height:1.85;max-width:720px;margin:0 auto 22px">
      Superpress, 2023 yılında Simpa Elektrik'in bir iştiraki olarak, elektrik kablolarının kesilip kablo
      pabuçlarının sıkılarak montaja hazır hale getirilmesi sürecinde kullanılan mekanik, hidrolik ve elektrikli
      el aletleri üretmek amacıyla kuruldu. Simpa Elektrik çatısı altında üretilen kablo pabuçlarıyla tam uyumlu
      sıkma penseleri, ürünlerimizin temelini oluşturuyor.
    </p>
    <a href="/hakkimizda" class="btn-p" style="display:inline-block">Daha Fazla Bilgi →</a>
  </div></div>

  <div class="sec" style="background:var(--g50)"><div class="sec-in">
    <div class="sec-hdr">
      <div><a href="/kategori/" class="sec-title title-link">Ürün <span>Grupları</span></a><div class="sec-sub">İhtiyacınıza uygun kablo el aletini seçin</div></div>
    </div>
    <div class="groups-grid">
      {categories.map((c) => (
        <a href={`/kategori/${c.slug}`} class="group-card">
          <div class="group-card-img">{c.image_url && <img src={c.image_url} alt={c.name} />}</div>
          <div class="group-card-body"><div class="group-card-name">{c.name}</div><div class="group-card-sub">{c.product_count} ürün serisi</div></div>
        </a>
      ))}
    </div>
  </div></div>
</div>

<!-- ══════════ MOBILE ══════════ -->
<div class="mobile-only">

  <div class="m-sec">
    <div style="text-align:center;padding:8px 4px 20px">
      <div class="m-about-lbl" style="color:var(--blue)">Hakkımızda</div>
      <h2 style="font-family:var(--cond);text-transform:uppercase;font-size:20px;color:var(--navy);margin:8px 0 12px">Kablo El Aletlerinde Uzman</h2>
      <p style="font-size:13.5px;color:var(--g600);line-height:1.8;margin-bottom:16px">
        Superpress, 2023 yılında Simpa Elektrik'in bir iştiraki olarak kuruldu. Simpa Elektrik çatısı altında
        üretilen kablo pabuçlarıyla tam uyumlu sıkma penseleri, ürünlerimizin temelini oluşturuyor.
      </p>
      <a href="/hakkimizda" class="m-btn-p" style="display:inline-block">Daha Fazla Bilgi →</a>
    </div>
  </div>

  <div class="m-sec" style="background:var(--g50)">
    <a href="/kategori/" class="title-link" style="display:block"><h2 style="font-family:var(--cond);text-transform:uppercase;font-size:20px;color:var(--navy);margin-bottom:14px">Ürün Grupları</h2></a>
    <div class="m-groups-grid">
      {categories.map((c) => (
        <a href={`/kategori/${c.slug}`} class="m-group-card">
          <div class="m-group-card-img">{c.image_url && <img src={c.image_url} alt={c.name} />}</div>
          <div class="m-group-card-body"><div class="m-group-card-name">{c.name}</div><div class="m-group-card-sub">{c.product_count} ürün serisi</div></div>
        </a>
      ))}
    </div>
  </div>
</div>
</Layout>
